# Base de datos
DATABASE_URL="postgresql://aeromx:aeromx123@127.0.0.1:5433/aeromx"

# JWT
JWT_SECRET="cambia_este_secreto_en_produccion"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3000
NODE_ENV=development

# Almacenamiento de fotos (MinIO o S3)
STORAGE_PROVIDER=minio   # minio | s3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aeromx-fotos

# AWS S3 (si STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=aeromx-fotos

# CORS
CORS_ORIGIN=http://localhost:5173
